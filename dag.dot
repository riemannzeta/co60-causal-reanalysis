  "Cancer" [style=solid, fillcolor="white", label="Cancer"];
  "AttainedAge" [style=solid, fillcolor="white", label="AttainedAge"];
  "CalendarPeriod" [style=solid, fillcolor="white", label="CalendarPeriod"];
  "Smoking" [style=filled, fillcolor="#eeeeee", label="Smoking (unmeasured)"];
  "ReproHistory" [style=filled, fillcolor="#eeeeee", label="ReproHistory (unmeasured)"];
  "Selection" [style=filled, fillcolor="#eeeeee", label="Selection (unmeasured)"];
  "Building" -> "TrueDose";
  "TrueDose" -> "AssignedDose";
  "TrueDose" -> "Cancer";
  "SES" -> "Building";
  "SES" -> "Cancer";
  "SES" -> "Smoking";
  "SES" -> "Selection";
  "DoseError" -> "AssignedDose";
  "AgeAtExposure" -> "AssignedDose";
  "AgeAtExposure" -> "Cancer";
  "AgeAtExposure" -> "AttainedAge";
  "AgeAtExposure" -> "Selection";
  "Sex" -> "AssignedDose";
  "Sex" -> "Cancer";
  "AttainedAge" -> "Cancer";
  "CalendarPeriod" -> "Cancer";
  "Smoking" -> "Cancer";
  "ReproHistory" -> "Cancer";
}
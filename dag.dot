digraph co60 {
  rankdir=LR;
  node [shape=box, fontname="Helvetica"];
  "Building" [style=solid, fillcolor="white", label="Building"];
  "TrueDose" [style=filled, fillcolor="#eeeeee", label="TrueDose (unmeasured)"];
  "SES" [style=filled, fillcolor="#eeeeee", label="SES (unmeasured)"];
